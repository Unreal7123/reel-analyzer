# ── Backend env vars ──────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
# Default: localhost only
CORS_ORIGINS=http://localhost,http://localhost:3000

# Sub-path if deployed behind a reverse proxy (e.g. /api)
ROOT_PATH=/api

# ── Frontend env vars (Vite — prefix with VITE_) ─────────────────────────────
# Full URL of the backend API (empty string = same origin via nginx proxy)
VITE_API_URL=
